---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      Projects — Go Izumita / 泉田剛
    </title>

    <meta
      name="description"
      content="泉田剛のプロジェクト一覧。彫刻、インスタレーション、建築、メディアアート、空間デザインなど。"
    />

    <meta
      property="og:title"
      content="Projects — Go Izumita / 泉田剛"
    />

    <meta
      property="og:description"
      content="泉田剛のプロジェクト一覧"
    />

    <meta
      property="og:image"
      content="https://goizumita.com/images/og.jpg"
    />

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:url"
      content="https://goizumita.com/jp/projects"
    />

    <link
      rel="icon"
      href="/favicon.ico"
    />

    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon.png"
    />
  </head>

  <body>
    <Header />

    <main class="project-list">
      <a
        href="/jp/projects/disassembly"
        class="project-row"
      >
        <div>
          解体と記憶
        </div>

        <div>
          彫刻、インスタレーション
        </div>

        <div>
          青森県立美術館
        </div>

        <div>
          2025
        </div>
      </a>

      <a
        href="/jp/projects/encounters"
        class="project-row"
      >
        <div>
          ENCOUNTERS
        </div>

        <div>
          メディアアート、展示
        </div>

        <div>
          TODA HALL & CONFERENCE TOKYO
        </div>

        <div>
          2026
        </div>
      </a>

      <a
        href="/jp/projects/architecture-complexity-mapping"
        class="project-row"
      >
        <div>
          Architecture Complexity
          Mapping Patterns of
          Architecture
        </div>

        <div>
          リサーチ、建築
        </div>

        <div>
          武蔵野美術大学
        </div>

        <div>
          2024
        </div>
      </a>

      <a
        href="/jp/projects/revolve"
        class="project-row"
      >
        <div>
          R/EVOLVE
        </div>

        <div>
          ステージデザイン、施工
        </div>

        <div>
          武蔵野美術大学
        </div>

        <div>
          2023
        </div>
      </a>
    </main>
    <Footer />
  </body>
</html>