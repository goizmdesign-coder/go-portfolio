---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      泉田剛 / Go Izumita — Artist &
      Architectural Designer
    </title>

    <meta
      name="description"
      content="泉田剛（Go Izumita）のポートフォリオサイト。建築、アート、解体と記憶をテーマに、解体と再構築による作品制作を行うアーティスト / 建築デザイナー。"
    />

    <meta
      property="og:title"
      content="泉田剛 / Go Izumita"
    />

    <meta
      property="og:description"
      content="Artist and Architectural Designer"
    />

    <meta
      property="og:image"
      content="https://goizumita.com/images/og.jpg"
    />

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:url"
      content="https://goizumita.com/jp"
    />

    <link
      rel="icon"
      href="/favicon.ico"
    />

    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon.png"
    />
  </head>

  <body>
    <Header />

    <main class="home-grid">
      <a
        href="/jp/projects/disassembly"
        class="work-item"
      >
        <img
          src="/images/work-01.jpg"
          alt="解体と記憶 — 泉田剛"
        />

        <div class="work-title">
          解体と記憶
        </div>
      </a>

      <a
        href="/jp/projects/encounters"
        class="work-item"
      >
        <img
          src="/images/work-02.jpg"
          alt="ENCOUNTERS — 泉田剛"
        />

        <div class="work-title">
          ENCOUNTERS 2025
        </div>
      </a>

      <a
        href="/jp/projects/architecture-complexity-mapping"
        class="work-item"
      >
        <img
          src="/images/work-03.jpg"
          alt="Architecture Complexity Mapping — 泉田剛"
        />

        <div class="work-title">
          Architecture Complexity
          Mapping
          <br />
          Patterns of Architecture
        </div>
      </a>

      <a
        href="/jp/projects/revolve"
        class="work-item"
      >
        <img
          src="/images/work-04.jpg"
          alt="R/EVOLVE — 泉田剛"
        />

        <div class="work-title">
          R/EVOLVE
        </div>
      </a>
    </main>
  </body>
</html>