---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      ENCOUNTERS 2025 — Go Izumita / 泉田剛
    </title>

    <meta
      name="description"
      content="Installation work exhibited at the Agency for Cultural Affairs Media Arts Creator Development Support Program Final Exhibition at TODA HALL & CONFERENCE TOKYO."
    />

    <meta
      property="og:title"
      content="ENCOUNTERS 2025 — Go Izumita / 泉田剛"
    />

    <meta
      property="og:description"
      content="Installation and Exhibition Project"
    />

    <meta
      property="og:image"
      content="https://goizumita.com/images/toda-1.jpg"
    />

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:url"
      content="https://goizumita.com/projects/encounters"
    />

    <link
      rel="icon"
      href="/favicon.ico"
    />

    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon.png"
    />
  </head>

  <body>
    <Header />

    <main>
      <h1>
        ENCOUNTERS 2025
      </h1>

      <p>
        Agency for Cultural Affairs
        Media Arts Creator
        Development Support Program
        — Final Exhibition.
        Disassembly and Memory —
        Texture Displaced:
        The Displacement Between
        Architectural Model and
        Material Through
        Dismantling.
      </p>

      <p>
        The work originally presented
        in the solo exhibition was
        further developed and
        exhibited at the final
        presentation of the Agency for
        Cultural Affairs Media Arts
        Creator Development Support
        Program.
      </p>

      <p>
        The venue was TODA BUILDING
        4F, TODA HALL & CONFERENCE
        TOKYO.
      </p>

      <p>
        Within a dense urban context
        of high-rise buildings, the
        sculpture — constructed from
        materials of a dismantled shed
        — appears as a sudden and
        striking presence.
      </p>

      <p>
        This juxtaposition creates a
        contrast that evokes both the
        advancement of architectural
        technology and the layered
        history of urban space.
      </p>

      <p>
        Inside the sculpture, a
        lampshade replicating its
        external form is installed,
        emitting a gently flickering
        light.
      </p>

      <p>
        This installation generates a
        sense of festivity that invites
        reflection on the idea of home
        and family, as well as on
        communities that have been
        lost through processes of
        urbanization.
      </p>

      <p>
        Photo : Ryujin / Go Izumita
      </p>

      <img
        src="/images/work-02.jpg"
        alt="ENCOUNTERS 2025 — Go Izumita"
      />

      <img
        src="/images/toda-1.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />

      <img
        src="/images/toda-2.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />

      <img
        src="/images/toda-3.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />

      <img
        src="/images/toda-4.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />

      <img
        src="/images/toda-5.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />

      <img
        src="/images/toda-6.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />

      <img
        src="/images/toda-7.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />

      <img
        src="/images/toda-12.jpg"
        alt="ENCOUNTERS 2025 installation view"
      />
      <a
  href="#"
  class="next-project"
  id="random-next"
>
  NEXT
</a>

<script>
  const projects = [
    "/projects/disassembly",
    "/projects/encounters",
    "/projects/architecture-complexity-mapping",
    "/projects/revolve"
  ];

  const current =
    window.location.pathname;

  const filtered =
    projects.filter(
      (p) => p !== current
    );

  const random =
    filtered[
      Math.floor(
        Math.random() * filtered.length
      )
    ];

  document
    .getElementById("random-next")
    .href = random;
</script>
    </main>
    <Footer />
  </body>
</html>