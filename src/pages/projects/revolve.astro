---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      R/EVOLVE — Go Izumita / 泉田剛
    </title>

    <meta
      name="description"
      content="Stage design and construction project exploring immersive spatial experiences through sound, image, and architecture."
    />

    <meta
      property="og:title"
      content="R/EVOLVE — Go Izumita / 泉田剛"
    />

    <meta
      property="og:description"
      content="Stage Design and Spatial Installation Project"
    />

    <meta
      property="og:image"
      content="https://goizumita.com/images/revolve-1.jpg"
    />

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:url"
      content="https://goizumita.com/projects/revolve"
    />

    <link
      rel="icon"
      href="/favicon.ico"
    />

    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon.png"
    />
  </head>

  <body>
    <Header />

    <main>
      <h1>
        R/EVOLVE
      </h1>

      <p>
        A stage design and
        construction project developed
        through activities with the
        Electronic Music Research
        Society at Musashino Art
        University.
      </p>

      <p>
        By placing the stage at the
        center of the venue, the project
        transformed performances into
        spatial experiences that could
        be viewed from every direction.
        Audience, performers, sound,
        and projected images became
        integrated into a continuously
        evolving immersive
        environment.
      </p>

      <p>
        The project evolved from earlier
        experiments involving
        large-scale projection walls and
        circular screens, eventually
        leading to the construction of a
        massive curved screen
        approximately 21 meters in
        length with an extreme 7:1
        aspect ratio.
      </p>

      <p>
        Through modular construction
        systems and hands-on
        fabrication processes, the work
        explored new relationships
        between architecture, media,
        sound, and collective spatial
        experience.
      </p>

      <img
        src="/images/revolve-1.jpg"
        alt="R/EVOLVE — Go Izumita"
      />

      <img
        src="/images/revolve-2.jpg"
        alt="R/EVOLVE — Go Izumita"
      />

      <img
        src="/images/revolve-3.jpg"
        alt="R/EVOLVE — Go Izumita"
      />

      <img
        src="/images/revolve-4.jpg"
        alt="R/EVOLVE — Go Izumita"
      />

      <img
        src="/images/revolve-mov.gif"
        alt="R/EVOLVE animation — Go Izumita"
      />
      <a
  href="#"
  class="next-project"
  id="random-next"
>
  Next Project
</a>

<script>
  const projects = [
    "/projects/disassembly",
    "/projects/encounters",
    "/projects/architecture-complexity-mapping",
    "/projects/revolve"
  ];

  const current =
    window.location.pathname;

  const filtered =
    projects.filter(
      (p) => p !== current
    );

  const random =
    filtered[
      Math.floor(
        Math.random() * filtered.length
      )
    ];

  document
    .getElementById("random-next")
    .href = random;
</script>
    </main>
    <Footer />
  </body>
</html>