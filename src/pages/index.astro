---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      GO IZUMITA — Artist &
      Architectural Designer
    </title>

    <meta
      name="description"
      content="泉田剛（Go Izumita）のポートフォリオサイト。建築、アート、解体と記憶をテーマに、解体と再構築による作品制作を行うアーティスト / 建築デザイナー。"
    />

    <meta
      property="og:title"
      content="GO IZUMITA"
    />

    <meta
      property="og:description"
      content="Artist and Architectural Designer"
    />

    <meta
      property="og:image"
      content="https://goizumita.com/images/og.jpg"
    />

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:url"
      content="https://goizumita.com"
    />

    <link
      rel="icon"
      href="/favicon.ico"
    />

    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon.png"
    />
  </head>

  <body>
    <Header />

    <main class="home-grid">
      <a
        href="/projects/disassembly"
        class="work-item"
      >
        <img
          src="/images/work-01.gif"
          alt="Deconstruction and Memory — GO IZUMITA"
        />

        <div class="work-title">
          Deconstruction and Memory
        </div>
      </a>

      <a
        href="/projects/encounters"
        class="work-item"
      >
        <img
          src="/images/work-02.jpg"
          alt="ENCOUNTERS 2025 — GO IZUMITA"
        />

        <div class="work-title">
          ENCOUNTERS 2025
        </div>
      </a>

      <a
        href="/projects/architecture-complexity-mapping"
        class="work-item"
      >
        <img
          src="/images/work-03.jpg"
          alt="Architecture Complexity Mapping — GO IZUMITA"
        />

        <div class="work-title">
          Architecture Complexity
          Mapping
          <br />
          Patterns of Architecture
        </div>
      </a>

      <a
        href="/projects/revolve"
        class="work-item"
      >
        <img
          src="/images/work-04.jpg"
          alt="R/EVOLVE — GO IZUMITA"
        />

        <div class="work-title">
          R/EVOLVE
        </div>
      </a>
    </main>

    <Footer />
  </body>
</html>