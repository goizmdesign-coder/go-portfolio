---
const currentPath = Astro.url.pathname;

const isJP = currentPath.startsWith("/jp");

const jpHref = isJP
  ? currentPath
  : currentPath === "/"
    ? "/jp"
    : `/jp${currentPath}`;

const enHref = isJP
  ? currentPath.replace(/^\/jp/, "") || "/"
  : currentPath;

const aboutHref = isJP ? "/jp/about" : "/about";
---
<header class="site-header">
  <a href={isJP ? "/jp" : "/"}>
    GO IZUMITA
  </a>

  <nav>
    <a href="https://goizm.base.shop/" target="_blank">Store</a>

    <a
      href="/projects"
      class={currentPath.includes("/projects") ? "active" : ""}
    >
      Projects List
    </a>

    <a
      href={aboutHref}
      class={currentPath.includes("/about") ? "active" : ""}
    >
      About
    </a>

    <a
      href={jpHref}
      class={isJP ? "active" : ""}
    >
      JP
    </a>

    <a
      href={enHref}
      class={!isJP ? "active" : ""}
    >
      EN
    </a>
  </nav>
</header>