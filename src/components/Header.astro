
---
const currentPath =
  Astro.url.pathname.replace(/\/+$/, "") || "/";

const isSharedTextPage =
  currentPath === "/text";

const isJP =
  currentPath === "/jp" ||
  currentPath.startsWith("/jp/");

const jpHref = isSharedTextPage
  ? "/text"
  : isJP
    ? currentPath
    : currentPath === "/"
      ? "/jp"
      : `/jp${currentPath}`;

const enHref = isSharedTextPage
  ? "/text"
  : isJP
    ? currentPath.replace(/^\/jp/, "") || "/"
    : currentPath;

const aboutHref = isJP
  ? "/jp/about"
  : "/about";

const projectsHref = isJP
  ? "/jp/projects"
  : "/projects";
---

<header class="site-header">
  <a href={isJP ? "/jp" : "/"}>
    GO IZUMITA
  </a>

  <nav>
    <a
      href={projectsHref}
      class={currentPath.includes("/projects") ? "active" : ""}
    >
      Projects
    </a>

    <a
      href={aboutHref}
      class={currentPath.includes("/about") ? "active" : ""}
    >
      About
    </a>

    <a
      href={jpHref}
      class={!isSharedTextPage && isJP ? "active" : ""}
    >
      JP
    </a>

    <a
      href={enHref}
      class={!isSharedTextPage && !isJP ? "active" : ""}
    >
      EN
    </a>
  </nav>
</header>

